{
  "info": {
    "name": "Spring JWT Todo API",
    "description": "Auth and Todo endpoints for the Spring JWT Todo API. Set baseUrl (default http://localhost:8080). After Login, accessToken and refreshToken are saved for use in Todo requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "todoId", "value": "1" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"USER\"\n}"
            },
            "url": "{{baseUrl}}/api/todos/v1/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) pm.collectionVariables.set('accessToken', res.accessToken);",
                  "if (res.refreshToken) pm.collectionVariables.set('refreshToken', res.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/api/todos/v1/auth/login"
          }
        },
        {
          "name": "Refresh",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/plain" }],
            "body": {
              "mode": "raw",
              "raw": "{{refreshToken}}"
            },
            "url": "{{baseUrl}}/api/todos/v1/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "text/plain" }],
            "body": {
              "mode": "raw",
              "raw": "{{refreshToken}}"
            },
            "url": "{{baseUrl}}/api/todos/v1/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Todos",
      "item": [
        {
          "name": "Create Todo",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"task\": \"Write documentation\"\n}"
            },
            "url": "{{baseUrl}}/api/todos/v1/create"
          }
        },
        {
          "name": "Get All Todos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/todos/v1"
          }
        },
        {
          "name": "Update Todo",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"task\": \"Updated documentation\"\n}"
            },
            "url": "{{baseUrl}}/api/todos/v1/update/{{todoId}}"
          }
        },
        {
          "name": "Mark Todo Done",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/todos/v1/done/{{todoId}}"
          }
        },
        {
          "name": "Delete Todo",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/todos/v1/delete/{{todoId}}"
          }
        }
      ]
    }
  ]
}
